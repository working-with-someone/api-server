{
  "compilerOptions": {
    "target": "es6",
    "module": "commonjs",
    "outDir": "dist",
    "rootDir": "./",
    "strict": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "typeRoots": [
      "src/types/merging",
      "./node_modules/@types",
    ]
  },
  "include": [
    "src",
    "tests"
  ],
  "exclude": [
    "node_modules",
  ],
  "ts-node": {
    "files": true // ts-node가 global.d.ts 파일을 강제로 로드하도록 설정
  }
}